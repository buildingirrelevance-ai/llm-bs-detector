{
  "manifest_version": 3,
  "name": "LLM BS Detector",
  "version": "0.1.0",
  "description": "Flags ungrounded confidence and hedge-word patterns in LLM responses. Helps you spot when an AI is pattern-matching from training instead of actually verifying.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["detector.js", "content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "panel.html",
    "default_title": "LLM BS Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}